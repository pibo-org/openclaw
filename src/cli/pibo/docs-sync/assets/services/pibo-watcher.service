[Unit]
Description=PIBo Docs Auto-Push Watcher
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart={{NODE_BIN}} {{SCRIPTS_DIR}}/pibo-watcher.js
Restart=always
RestartSec=5
WorkingDirectory={{DOCS_PATH}}
Environment=HOME={{HOME}}
Environment=PATH={{NODE_BIN_DIR}}:{{PATH}}

[Install]
WantedBy=default.target
