server {
    listen 80;
    listen [::]:80;
    server_name chat.pibo.schottech.de www.chat.pibo.schottech.de;
    return 301 https://pibo.schottech.de/chat$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name chat.pibo.schottech.de www.chat.pibo.schottech.de;

    ssl_certificate /etc/letsencrypt/live/chat.pibo.schottech.de/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chat.pibo.schottech.de/privkey.pem;
    return 301 https://pibo.schottech.de/chat$request_uri;
}
