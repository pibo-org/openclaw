#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
RUN_NODE_TOOL="$ROOT_DIR/scripts/pre-commit/run-node-tool.sh"
FILTER_FILES="$ROOT_DIR/scripts/pre-commit/filter-staged-files.mjs"

if [[ ! -x "$RUN_NODE_TOOL" ]]; then
  echo "Missing helper: $RUN_NODE_TOOL" >&2
  exit 1
fi

if [[ ! -f "$FILTER_FILES" ]]; then
  echo "Missing helper: $FILTER_FILES" >&2
  exit 1
fi

is_truthy_env() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

PRECOMMIT_MODE=""
PRECOMMIT_MODE_SOURCE=""
openclaw_precommit_mode_is_set="${OPENCLAW_PRECOMMIT_MODE+x}"
if [[ -n "$openclaw_precommit_mode_is_set" ]]; then
  case "${OPENCLAW_PRECOMMIT_MODE}" in
    strict)
      PRECOMMIT_MODE="strict"
      PRECOMMIT_MODE_SOURCE="OPENCLAW_PRECOMMIT_MODE=strict"
      ;;
    hotfix)
      PRECOMMIT_MODE="hotfix"
      PRECOMMIT_MODE_SOURCE="OPENCLAW_PRECOMMIT_MODE=hotfix"
      ;;
    *)
      echo "Invalid OPENCLAW_PRECOMMIT_MODE='${OPENCLAW_PRECOMMIT_MODE}'. Expected one of: strict, hotfix." >&2
      exit 1
      ;;
  esac
elif is_truthy_env "${FAST_COMMIT:-}"; then
  PRECOMMIT_MODE="hotfix"
  PRECOMMIT_MODE_SOURCE="FAST_COMMIT alias"
else
  PRECOMMIT_MODE="strict"
  PRECOMMIT_MODE_SOURCE="default"
fi

# Security: avoid option-injection from malicious file names (e.g. "--all", "--force").
# Robustness: NUL-delimited file list handles spaces/newlines safely.
# Compatibility: use read loops instead of `mapfile` so this runs on macOS Bash 3.x.
files=()
while IFS= read -r -d '' file; do
  files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "${#files[@]}" -eq 0 ]; then
  exit 0
fi

lint_files=()
while IFS= read -r -d '' file; do
  lint_files+=("$file")
done < <(node "$FILTER_FILES" lint -- "${files[@]}")

format_files=()
while IFS= read -r -d '' file; do
  format_files+=("$file")
done < <(node "$FILTER_FILES" format -- "${files[@]}")

docs_only=true
for file in "${files[@]}"; do
  case "$file" in
    docs/*|*.md|*.mdx)
      ;;
    *)
      docs_only=false
      break
      ;;
  esac
done

if [ "${#lint_files[@]}" -gt 0 ]; then
  "$RUN_NODE_TOOL" oxlint --type-aware --fix -- "${lint_files[@]}"
fi

if [ "${#format_files[@]}" -gt 0 ]; then
  "$RUN_NODE_TOOL" oxfmt --write --no-error-on-unmatched-pattern "${format_files[@]}"
fi

git add -- "${files[@]}"

# This hook is also exercised from lightweight temp repos in tests, where the
# staged-file safety behavior matters but the full OpenClaw workspace does not
# exist. Only run the repo-wide validation gate inside a real checkout.
if [[ -f "$ROOT_DIR/package.json" ]] && [[ -f "$ROOT_DIR/pnpm-lock.yaml" ]]; then
  cd "$ROOT_DIR"
  echo "Pre-commit mode: $PRECOMMIT_MODE ($PRECOMMIT_MODE_SOURCE)."
  if [[ "$PRECOMMIT_MODE" == "hotfix" ]]; then
    echo "Hotfix mode: skipping repo-wide pnpm check in pre-commit hook."
  elif [[ "$docs_only" == true ]]; then
    echo "Docs-only staged changes detected: skipping repo-wide pnpm check in pre-commit hook."
  else
    echo "Strict mode: running repo-wide pnpm check for non-docs staged changes."
    pnpm check
  fi
fi
